# Smart Commerce AI — Required Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file containing actual values to version control.

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/smart_ai"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Encryption (for pageAccessTokenEncrypted and Integration Layer credentials)
ENCRYPTION_KEY="your-encryption-key"

# Facebook App
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"

# SMS/OTP Provider (optional — required only when phone verification is enabled)
SMS_PROVIDER_API_KEY="your-sms-provider-api-key"
SMS_PROVIDER_API_SECRET="your-sms-provider-api-secret"

# Integration Layer Credential Hashing
INTEGRATION_CREDENTIAL_SALT="your-integration-credential-salt"
